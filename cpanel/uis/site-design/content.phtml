<script>
    $(function() {
        let notify_error = {status: 'error',title: 'Site Design',text: 'Failed to updated this settings',effect: 'slide',speed: 600,customClass: '',customIcon: '',showIcon: true,showCloseButton: true,autoclose: true,autotimeout: 3000,gap: 20,distance: 20,type: 1,position: 'right bottom',customWrapper: ''}
        let notify_warning = {status: 'warning',title: 'Site Design',text: "Oops there's an error in the script",effect: 'slide',speed: 600,customClass: '',customIcon: '',showIcon: true,showCloseButton: true,autoclose: true,autotimeout: 3000,gap: 20,distance: 20,type: 1,position: 'right bottom',customWrapper: ''}
        let notify_success = {status: 'success',title: 'Site Design',text: 'Design Updated Successfully',effect: 'slide',speed: 600,customClass: '',customIcon: '',showIcon: true,showCloseButton: true,autoclose: true,autotimeout: 3000,gap: 20,distance: 20,type: 1,position: 'right bottom',customWrapper: ''}

        $('mwc-select').on('change', function() {
            var thisElement = $(this);
            var configName = thisElement.attr('name');
            var hash_id = $('input[name=hash_id]').val();
            var objData = {};
            objData[configName] = thisElement.val();
            objData['hash_id'] = hash_id;
            $.post(cpanel_ajax_url('general-settings'), objData, function (data) {
                if (data.status == 200) {
                    new Notify({ ...notify_success });
                } else {
                    new Notify({ ...notify_error });
                }
            });
        });

        $("#favicon").change(function () {
            var filename = $(this).val().replace(/C:\\fakepath\\/i, '');
            $("#favicon-i input").val(filename);
            $("#favicon-i").removeClass('hidden');
        });
        $("#logo").change(function () {
            var filename = $(this).val().replace(/C:\\fakepath\\/i, '');
            $("#logo-i input").val(filename);
            $("#logo-i").removeClass('hidden');
        });
        $("#light-logo").change(function () {
            var filename = $(this).val().replace(/C:\\fakepath\\/i, '');
            $("#logo-li input").val(filename);
            $("#logo-li").removeClass('hidden');
        });

        var form = $('form#site-design');
        form.ajaxForm({
            url: cpanel_ajax_url('update-design'),
            beforeSend: function() {
                form.find('.btn-outline-primary').text('Please wait..');
            },
            success: function(data) {
                if (data.status == 200) {
                    form.find('.btn-outline-primary').html('Save Changes <i class="trailing-icon material-icons">arrow_forward</i>');
                    $("html, body").animate({ scrollTop: 0 }, "slow");
                    new Notify({ ...notify_success });
                }
            }
        });

        $("#logo-day").change(function () {
            var filename = $(this).val().replace(/C:\\fakepath\\/i, '');
            $("#logo-ci input").val(filename);
            $("#logo-ci").removeClass('hidden');
        });
        $("#logo-night").change(function () {
            var filename = $(this).val().replace(/C:\\fakepath\\/i, '');
            $("#logo-cli input").val(filename);
            $("#logo-cli").removeClass('hidden');
        });

        var form = $('form#cpanel-design');
        form.ajaxForm({
            url: cpanel_ajax_url('cpanel-design'),
            beforeSend: function() {
                form.find('.btn-outline-primary').text('Please wait..');
            },
            success: function(data) {
                if (data.status == 200) {
                    form.find('.btn-outline-primary').html('Save Changes <i class="trailing-icon material-icons">arrow_forward</i>');
                    let notify_success = {status: 'success',title: 'Site Design',text: 'Cpanel Updated Successfully',effect: 'slide',speed: 600,customClass: '',customIcon: '',showIcon: true,showCloseButton: true,autoclose: true,autotimeout: 3000,gap: 20,distance: 20,type: 1,position: 'right bottom',customWrapper: ''}
                    new Notify({ ...notify_success });
                    location.reload(0);
                }
            }
        });

    });
</script>