function UnpublishArticle(id,obj){
    if (id == '') {
        return false;
    }
    $(obj).addClass('btn-outline-secondary');
    $(obj).removeClass('btn-outline-dark');
    $(obj).text('PUBLISH');
    $(obj).attr('onclick','PublishArticle('+id+',this);');
    $.get(cpanel_ajax_url('unpublish_blog_article'), {id:id});
    $('#redirect_link').attr('href', "<?php echo cpanel('manage-articles'); ?>");
    $('#redirect_link').attr('data-ajax', "?path=manage-articles");
    $('#redirect_link').click();
    let notify_success201 = {status: 'success',title: 'Manage Articles',text: "Article unpublish successfully!",effect: 'slide',speed: 600,customClass: '',customIcon: '',showIcon: true,showCloseButton: true,autoclose: true,autotimeout: 3000,gap: 20,distance: 20,type: 1,position: 'right bottom',customWrapper: ''}
    new Notify({ ...notify_success201 });
}
function PublishArticle(id,obj){
    if (id == '') {
        return false;
    }
    $(obj).removeClass('btn-outline-info');
    $(obj).addClass('btn-outline-success');
    $(obj).text('UNPUBLISH');
    $(obj).attr('onclick','UnpublishArticle('+id+',this);');
    $.get(cpanel_ajax_url('publish_blog_article'), {id:id});
    $('#redirect_link').attr('href', "<?php echo cpanel('manage-articles'); ?>");
    $('#redirect_link').attr('data-ajax', "?path=manage-articles");
    $('#redirect_link').click();
    let notify_success201 = {status: 'success',title: 'Manage Articles',text: "Article publish successfully!",effect: 'slide',speed: 600,customClass: '',customIcon: '',showIcon: true,showCloseButton: true,autoclose: true,autotimeout: 3000,gap: 20,distance: 20,type: 1,position: 'right bottom',customWrapper: ''}
    new Notify({ ...notify_success201 });
}

function DeleteArticle(id,thumbnail,type = 'show') {
    if (type == 'hide') {
        $('#DeleteModal').find('.btn-outline-danger').attr('onclick', "DeleteArticle('"+id+"','"+thumbnail+"')");
        $('#DeleteModal').modal('show');
        return false;
    }
    $('#list-' + id).fadeOut(400, function () {
        $(this).remove();
    });
    $.get(cpanel_ajax_url('delete_blog_article'), {id:id, thumbnail:thumbnail});
    $('#DeleteModal').modal('hide');
    $('#redirect_link').attr('href', "<?php echo cpanel('manage-articles'); ?>");
    $('#redirect_link').attr('data-ajax', "?path=manage-articles");
    $('#redirect_link').click();
    let notify_success201 = {status: 'success',title: 'Manage Articles',text: "Article deleted successfully!",effect: 'slide',speed: 600,customClass: '',customIcon: '',showIcon: true,showCloseButton: true,autoclose: true,autotimeout: 3000,gap: 20,distance: 20,type: 1,position: 'right bottom',customWrapper: ''}
    new Notify({ ...notify_success201 });
}

