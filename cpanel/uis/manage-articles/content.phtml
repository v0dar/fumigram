function DeleteSelected() {
    action_type = $('#action_type').val();
    data = new Array();
    $('td input:checked').parents('tr').each(function () {
        data.push($(this).attr('data_selected'));
    });
    $('.delete-selected').attr('disabled', true);
    $('.delete-selected').text('Please wait...');
    $.post(cpanel_ajax_url('delete_multi_article'), {ids: data, type: action_type}, function () {
        if (action_type == 'Publish') {
            let notify_200 = {status: 'success',title: 'Manage Articles',text: 'The selected users articles was publish',effect: 'slide',speed: 600,customClass: '',customIcon: '',showIcon: true,showCloseButton: true,autoclose: true,autotimeout: 3000,gap: 20,distance: 20,type: 1,position: 'right bottom',customWrapper: ''}          
            new Notify({ ...notify_200 });
            $('#SelectedDeleteModal').modal('hide');
            $('#redirect_link').attr('href', "<?php echo cpanel('manage-articles'); ?>");
            $('#redirect_link').attr('data-ajax', "?path=manage-articles");
            $('#redirect_link').click();
        } else if (action_type == 'Unpublish') {
            $('#SelectedDeleteModal').modal('hide');
            $('#redirect_link').attr('href', "<?php echo cpanel('manage-articles'); ?>");
            $('#redirect_link').attr('data-ajax', "?path=manage-articles");
            $('#redirect_link').click();
            let notify_success200 = {status: 'success',title: 'Manage Articles',text: 'The selected users articles was unpublish!',effect: 'slide',speed: 600,customClass: '',customIcon: '',showIcon: true,showCloseButton: true,autoclose: true,autotimeout: 3000,gap: 20,distance: 20,type: 1,position: 'right bottom',customWrapper: ''}
            new Notify({ ...notify_success200 });
        } else if (action_type == 'Delete') {
            $('#SelectedDeleteModal').modal('hide');
            $.each( data, function( index, value ){$('#list-' + value).remove();});
            $('#redirect_link').attr('href', "<?php echo cpanel('manage-articles'); ?>");
            $('#redirect_link').attr('data-ajax', "?path=manage-articles");
            $('#redirect_link').click();
            let notify_success201 = {status: 'success',title: 'Manage Articles',text: "Successfully deleted the selected users articles!",effect: 'slide',speed: 600,customClass: '',customIcon: '',showIcon: true,showCloseButton: true,autoclose: true,autotimeout: 3000,gap: 20,distance: 20,type: 1,position: 'right bottom',customWrapper: ''}
            new Notify({ ...notify_success201 });
        } else {
            location.reload();
        }
        $('#SelectedDeleteModal').modal('hide');
        $('.delete-selected').text('Take Action');
    });
}
