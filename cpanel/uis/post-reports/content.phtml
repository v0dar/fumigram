<script>
$('.check-all').on('click', function(event) {
    $('input:checkbox').not(this).prop('checked', this.checked);
});
$('.delete-checkbox, .check-all').change(function(event) {
    $('.delete-selected').attr('disabled', false);
    $('.delete-selected').find('span').text(' (' + $('.delete-checkbox:checked').length + ')');
});
$('.delete-selected').on('click', function(event) {
    event.preventDefault();
    action_type = $('#action_type').val();
    if (action_type == 'mark_safe') {
        $('#SelectedDeleteModal').find('.modal-body').html('Are you sure you want to mark the selected posts as a safe content?');
        $('#SelectedDeleteModal').find('#exampleModalCenteredLabel').html('Mark Safe!');
        $('#SelectedDeleteModal').find('.btn-outline-primary').text('Mark Safe');
        $('#SelectedDeleteModal').modal('show');
    } else {
        $('#SelectedDeleteModal').find('.modal-body').html('Are you sure that you want to delete the selected post(s)?');
        $('#SelectedDeleteModal').find('#exampleModalCenteredLabel').html('Delete Posts!');
        $('#SelectedDeleteModal').find('.btn-outline-primary').text('Delete Posts');
        $('#SelectedDeleteModal').modal('show');
    }
});
function DeleteSelected() {
    action_type = $('#action_type').val();
    data = new Array();
    $('td input:checked').parents('tr').each(function () {
        data.push($(this).attr('data_selected'));
    });
    $('.delete-selected').attr('disabled', true);
    $('.delete-selected').text('Please wait...');
    $.post(cpanel_ajax_url('update-post_reports'), {ids: data, type: action_type}, function () {
        if (action_type == 'mark_safe') {
            let notify_200 = {status: 'success',title: 'Post Reports',text: 'Successfully marked the selected post as safe',effect: 'slide',speed: 600,customClass: '',customIcon: '',showIcon: true,showCloseButton: true,autoclose: true,autotimeout: 3000,gap: 20,distance: 20,type: 1,position: 'right bottom',customWrapper: ''}
            new Notify({ ...notify_200 });
            $('#SelectedDeleteModal').modal('hide');
            $.each( data, function( index, value ){$('#list-' + value).remove();});
            $('#redirect_link').attr('href', "<?php echo cpanel('post-reports'); ?>");
            $('#redirect_link').attr('data-ajax', "?path=post-reports");
            $('#redirect_link').click();
        } else if (action_type == 'delete_post') {
            $('#redirect_link').attr('href', "<?php echo cpanel('post-reports'); ?>");
            $('#redirect_link').attr('data-ajax', "?path=post-reports");
            $('#redirect_link').click();
            let notify_success200 = {status: 'success',title: 'Post Reports',text: 'Successfully deleted the selected posts!',effect: 'slide',speed: 600,customClass: '',customIcon: '',showIcon: true,showCloseButton: true,autoclose: true,autotimeout: 3000,gap: 20,distance: 20,type: 1,position: 'right bottom',customWrapper: ''}
            new Notify({ ...notify_success200 });
            $('#SelectedDeleteModal').modal('hide');
        } else {
            location.reload();
        }
        $('#SelectedDeleteModal').modal('hide');
        $('.delete-selected').text('Take Action');
    });
}

function MarkSafe(id,type = 'show'){
    if (type == 'hide') {
        $('#MarkSafe').find('.btn-outline-primary').attr('onclick', "MarkSafe('"+id+"')");
        $('#MarkSafe').modal('show');
        return false;
    }
    $.post(cpanel_ajax_url('delete-report'), {id:id,t:2}, function(data, textStatus, xhr) {
        if (data.status == 200) {
            $('#MarkSafe').modal('hide');
            $('#list-' + id).fadeOut(300, function() {$(this).remove()});
            $('#redirect_link').attr('href', "<?php echo cpanel('post-reports'); ?>");
            $('#redirect_link').attr('data-ajax', "?path=post-reports");
            $('#redirect_link').click();
            let notify_success201 = {status: 'success',title: 'Post Reports',text: "Report Marked As Safe!",effect: 'slide',speed: 600,customClass: '',customIcon: '',showIcon: true,showCloseButton: true,autoclose: true,autotimeout: 3000,gap: 20,distance: 20,type: 1,position: 'right bottom',customWrapper: ''}
            new Notify({ ...notify_success201 });
        } else {
            $('#MarkSafe').modal('hide');
            $('#redirect_link').attr('href', "<?php echo cpanel('post-reports'); ?>");
            $('#redirect_link').attr('data-ajax', "?path=post-reports");
            $('#redirect_link').click();
            let notify_error = {status: 'error',title: 'Post Reports',text: "Failed to mark as safe!",effect: 'slide',speed: 600,customClass: '',customIcon: '',showIcon: true,showCloseButton: true,autoclose: true,autotimeout: 3000,gap: 20,distance: 20,type: 1,position: 'right bottom',customWrapper: ''}
            new Notify({ ...notify_error });
        }
    });
}
function DeletePost(id,type = 'show'){
        if (id && id > 0) {
            if (type == 'hide') {
                $('#DeletePost').find('.btn-outline-primary').attr('onclick', "DeletePost('"+id+"')");
                $('#DeletePost').modal('show');
                return false;
            }
            $("#DeletePost").modal("hide");
            $("#list-"+id).slideUp(function(){$(this).remove();});
            $.ajax({
                url: cpanel_ajax_url('delete-post'),
                type: 'POST',
                dataType: 'json',
                data: {id:id}
            });
            $('#redirect_link').attr('href', "<?php echo cpanel('post-reports'); ?>");
            $('#redirect_link').attr('data-ajax', "?path=post-reports");
            $('#redirect_link').click();
            let notify_success201 = {status: 'success',title: 'Post Reports',text: 'Post deleted Successfully!',effect: 'slide',speed: 600,customClass: '',customIcon: '',showIcon: true,showCloseButton: true,autoclose: true,autotimeout: 3000,gap: 20,distance: 20,type: 1,position: 'right bottom',customWrapper: ''}
            new Notify({ ...notify_success201 });
        }
}

