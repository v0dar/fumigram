<script>
$(function() {
    $('.check-all').on('click', function(event) {
        $('input:checkbox').not(this).prop('checked', this.checked);
    });
    $('.delete-checkbox, .check-all').change(function(event) {
        $('.delete-selected').attr('disabled', false);
        $('.delete-selected').find('span').text(' (' + $('.delete-checkbox:checked').length + ')');
    });

    $('.delete-selected').on('click', function(event) {
        event.preventDefault();
        $('#SelectedDeleteModal').modal('show');
    });
});

function DeleteSelectedNOPE() {
    data = new Array();
    $('td input:checked').parents('tr').each(function () {
        data.push($(this).attr('data_selected'));
    });
    $('.delete-selected').attr('disabled', true);
    $('.delete-selected').text('Please wait..');
    $.post(cpanel_ajax_url('remove_multi_lang'), {ids: data}, function () {
        $.each( data, function( index, value ){
            $('#' + value).remove();
        });
        $('#SelectedDeleteModal').modal('hide');
        let notify_success201 = {status: 'success',title: 'Languages',text: 'Delected the selected languages!',effect: 'slide',speed: 600,customClass: '',customIcon: '',showIcon: true,showCloseButton: true,autoclose: true,autotimeout: 3000,gap: 20,distance: 20,type: 1,position: 'right bottom',customWrapper: ''}
        new Notify({ ...notify_success201 });
        $('.delete-selected').text('Delete Selected');
        $('#redirect_link').attr('href', "<?php echo cpanel('manage-langs'); ?>");
        $('#redirect_link').attr('data-ajax', "?path=manage-langs");
        $('#redirect_link').click();
    });
}

function DeleteLang(id,type = 'show') {
    if (id == '') {
        return false;
    }
    if (type == 'hide') {
        $('#DeleteModal').find('.btn-outline-primary').attr('onclick', "DeleteLang('"+id+"')");
        $('#DeleteModal').modal('show');
        return false;
        }
                
    $('#' + id).fadeOut(300, function () {$(this).remove();});
    $.post(cpanel_ajax_url('delete-lang'), {id: id}, function(data, textStatus, xhr) {
        $('#DeleteModal').modal('hide');
        if (data.status == 200) {
            let notify_success201 = {status: 'success',title: 'Language',text: 'Language delected successfully!',effect: 'slide',speed: 600,customClass: '',customIcon: '',showIcon: true,showCloseButton: true,autoclose: true,autotimeout: 3000,gap: 20,distance: 20,type: 1,position: 'right bottom',customWrapper: ''}
            new Notify({ ...notify_success201 });
        } else {
            let notify_error = {status: 'error',title: 'Language',text: 'Failed to delete this language!',effect: 'slide',speed: 600,customClass: '',customIcon: '',showIcon: true,showCloseButton: true,autoclose: true,autotimeout: 3000,gap: 20,distance: 20,type: 1,position: 'right bottom',customWrapper: ''}
            new Notify({ ...notify_error });
        }
    });
}

$(function() {
    var form_key_settings = $('form.key-settings');
    form_key_settings.ajaxForm({
        url: cpanel_ajax_url('new-key'),
        beforeSend: function() {
            form_key_settings.find('button').text('Please wait...');
        },
        success: function(data) {
            if (data.status == 200) {
                $("html, body").animate({ scrollTop: 0 }, "slow");
                let notify_success201 = {status: 'success',title: 'Languages',text: 'Key successfully added!',effect: 'slide',speed: 600,customClass: '',customIcon: '',showIcon: true,showCloseButton: true,autoclose: true,autotimeout: 4000,gap: 20,distance: 20,type: 1,position: 'right top',customWrapper: ''}
                new Notify({ ...notify_success201 });
                $('#redirect_link').attr('href', "<?php echo cpanel('manage-langs'); ?>");
                $('#redirect_link').attr('data-ajax', "?path=manage-langs");
                $('#redirect_link').click();
            }
            else if(data.status == 401){
                let notify_error = {status: 'error',title: 'Languages',text: 'Invalid language key characters. Please use only english letters!',effect: 'slide',speed: 600,customClass: '',customIcon: '',showIcon: true,showCloseButton: true,autoclose: true,autotimeout: 4000,gap: 20,distance: 20,type: 1,position: 'right top',customWrapper: ''}
                new Notify({ ...notify_error });
                $('#redirect_link').attr('href', "<?php echo cpanel('manage-langs'); ?>");
                $('#redirect_link').attr('data-ajax', "?path=manage-langs");
                $('#redirect_link').click();
            }
            else if(data.status == 402){
                let notify_error = {status: 'error',title: 'Languages',text: 'Language key max length is 100 characters!',effect: 'slide',speed: 600,customClass: '',customIcon: '',showIcon: true,showCloseButton: true,autoclose: true,autotimeout: 4000,gap: 20,distance: 20,type: 1,position: 'right top',customWrapper: ''}
                new Notify({ ...notify_error });
                $('#redirect_link').attr('href', "<?php echo cpanel('manage-langs'); ?>");
                $('#redirect_link').attr('data-ajax', "?path=manage-langs");
                $('#redirect_link').click();
            }
            else if(data.status == 403){
                let notify_error = {status: 'error',title: 'Languages',text: 'This language key is already being used, Please use other one!',effect: 'slide',speed: 600,customClass: '',customIcon: '',showIcon: true,showCloseButton: true,autoclose: true,autotimeout: 4000,gap: 20,distance: 20,type: 1,position: 'right top',customWrapper: ''}
                new Notify({ ...notify_error });
                $('#redirect_link').attr('href', "<?php echo cpanel('manage-langs'); ?>");
                $('#redirect_link').attr('data-ajax', "?path=manage-langs");
                $('#redirect_link').click();
            }
            form_key_settings.find('button').text('Add Key');
        }
    });
});

$(function() {
    var form_new_langs = $('form.add-new-language');
