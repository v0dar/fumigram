            else if(data.status == 401){
                let notify_error = {status: 'error',title: 'Languages',text: 'Language name is invalid. Please enter a valid language name!',effect: 'slide',speed: 600,customClass: '',customIcon: '',showIcon: true,showCloseButton: true,autoclose: true,autotimeout: 4000,gap: 20,distance: 20,type: 1,position: 'right top',customWrapper: ''}
                new Notify({ ...notify_error });
                $('#redirect_link').attr('href', "<?php echo cpanel('manage-langs'); ?>");
                $('#redirect_link').attr('data-ajax', "?path=manage-langs");
                $('#redirect_link').click();
            }
            else if(data.status == 402){
                let notify_error = {status: 'error',title: 'Languages',text: 'This langguage is already being used!',effect: 'slide',speed: 600,customClass: '',customIcon: '',showIcon: true,showCloseButton: true,autoclose: true,autotimeout: 4000,gap: 20,distance: 20,type: 1,position: 'right top',customWrapper: ''}
                new Notify({ ...notify_error });
                $('#redirect_link').attr('href', "<?php echo cpanel('manage-langs'); ?>");
                $('#redirect_link').attr('data-ajax', "?path=manage-langs");
                $('#redirect_link').click();
            }
            form_new_langs.find('button').text('Add Language');
        }
    });
});

