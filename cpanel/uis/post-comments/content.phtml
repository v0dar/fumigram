<script>
$('.check-all').on('click', function(event) {
    $('input:checkbox').not(this).prop('checked', this.checked);
});
$('.delete-checkbox, .check-all').change(function(event) {
    $('.delete-selected').attr('disabled', false);
    $('.delete-selected').find('span').text(' (' + $('.delete-checkbox:checked').length + ')');
});
$('.delete-selected').on('click', function(event) {
    event.preventDefault();
    $('#SelectedDeleteModal').modal('show');
});
function DeleteSelected() {
    data = new Array();
    $('td input:checked').parents('tr').each(function () {
        data.push($(this).attr('data_selected'));
    });
    $('.delete-selected').attr('disabled', true);
    $('.delete-selected').text('Please wait...');
    $.post(cpanel_ajax_url('delete-multi-comments'), {ids: data}, function () {
        $.each( data, function( index, value ){
            $("#list-"+value).remove();
        });
        $('#SelectedDeleteModal').modal('hide');
        let notify_success201 = {status: 'success',title: 'Post Comments',text: 'Comments deleted Successfully!',effect: 'slide',speed: 600,customClass: '',customIcon: '',showIcon: true,showCloseButton: true,autoclose: true,autotimeout: 3000,gap: 20,distance: 20,type: 1,position: 'right bottom',customWrapper: ''}
        new Notify({ ...notify_success201 });
        $('#redirect_link').attr('href', "<?php echo cpanel('post-comments'); ?>");
        $('#redirect_link').attr('data-ajax', "?path=post-comments");
        $('#redirect_link').click();
        $('.delete-selected').text('Take Down');
    });
}
$('#Search').on('click', function(event) {
    event.preventDefault();
    var item = $('#query');
    var text = item.val();

    const accinput = $('#user_type');
    const AccType = accinput.val();
    $('#redirect_link').attr('href', "<?php echo cpanel('post-comments').$rang_link_href; ?>query="+text);
    $('#redirect_link').attr('data-ajax', "?path=post-comments<?php echo($search_link); ?>query="+text);
    $('#redirect_link').click();
});

function DeleteComment(id,type = 'show'){
  if (id && id > 0) {
    if (type == 'hide') {
      $('#DeleteModal').find('.btn-outline-danger').attr('onclick', "DeleteComment('"+id+"')");
      $('#DeleteModal').modal('show');
      return false;
    }
    $("#list-"+id).slideUp(function(){
      $(this).remove();
    });
    $("#DeleteModal").modal("hide");
    $.ajax({
      url: cpanel_ajax_url('delete-comments'),
      type: 'POST',
      dataType: 'json',
      data: {id:id}
    });
    $('#redirect_link').attr('href', "<?php echo cpanel('post-comments'); ?>");
    $('#redirect_link').attr('data-ajax', "?path=post-comments");
    $('#redirect_link').click();
    let notify_success201 = {status: 'success',title: 'Post Comments',text: 'Comments deleted Successfully!',effect: 'slide',speed: 600,customClass: '',customIcon: '',showIcon: true,showCloseButton: true,autoclose: true,autotimeout: 3000,gap: 20,distance: 20,type: 1,position: 'right bottom',customWrapper: ''}
    new Notify({ ...notify_success201 });
  }
}

