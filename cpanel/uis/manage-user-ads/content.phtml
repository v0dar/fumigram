function DeleteSelected() {
    data = new Array();
    $('td input:checked').parents('tr').each(function () {
        data.push($(this).attr('data_selected'));
    });
    $('.delete-selected').attr('disabled', true);
    $('.delete-selected').text('Please wait...');
    $.post(cpanel_ajax_url('remove_multi_ads'), {ids: data}, function () {
        $('#DeleteAdsModal').modal('hide');
        $.each( data, function( index, value ){
            $("tr[data-userad-id="+value+"]").remove();
        });
        $('.delete-selected').text('Delete Selected');
        $('#redirect_link').attr('href', "<?php echo cpanel('manage-user-ads'); ?>");
        $('#redirect_link').attr('data-ajax', "?path=manage-user-ads");
        $('#redirect_link').click();
        let notify_success201 = {status: 'success',title: 'Mambers Ads',text: "Ads delected successfully!",effect: 'slide',speed: 600,customClass: '',customIcon: '',showIcon: true,showCloseButton: true,autoclose: true,autotimeout: 3000,gap: 20,distance: 20,type: 1,position: 'right bottom',customWrapper: ''}
        new Notify({ ...notify_success201 });
    });
}

function DeleteAd(id,type = 'show'){
  if (id && id > 0) {
    if (type == 'hide') {
        $('#DeleteModal').find('.btn-outline-danger').attr('onclick', "DeleteAd('"+id+"')");
        $('#DeleteModal').modal('show');
        return false;
    }
    $("tr[data-userad-id="+id+"]").slideUp(function(){ $(this).remove(); });
    $("#DeleteModal").modal("hide");
    $.ajax({ url: cpanel_ajax_url('delete-ad'), type: 'POST', dataType: 'json', data: {id:id} });
    $('#DeleteModal').modal('hide');
    $('#redirect_link').attr('href', "<?php echo cpanel('manage-user-ads'); ?>");
    $('#redirect_link').attr('data-ajax', "?path=manage-user-ads");
    $('#redirect_link').click();
    let notify_success201 = {status: 'success',title: 'Mambers Ads',text: "Ad delected successfully!",effect: 'slide',speed: 600,customClass: '',customIcon: '',showIcon: true,showCloseButton: true,autoclose: true,autotimeout: 3000,gap: 20,distance: 20,type: 1,position: 'right bottom',customWrapper: ''}
    new Notify({ ...notify_success201 });
  }
}

