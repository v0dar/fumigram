    }
    elseif ($_GET['filter'] == 'female') {
        $cpanel::$db->where('gender', 'female');
        $cpanel::$db->pageLimit  = 50;
    }
    elseif ($_GET['filter'] == 'clicks') {
        $cpanel::$db->where('bidding', 'clicks');
        $cpanel::$db->pageLimit  = 50;
    }
    elseif ($_GET['filter'] == 'views') {
        $cpanel::$db->where('bidding', 'views');
        $cpanel::$db->pageLimit  = 50;
    }
}

