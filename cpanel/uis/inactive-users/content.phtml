function DeleteAcc(id, type = 'show') {
    let notify_error = {status: 'error',title: 'Inactive Users',text: 'Failed to delete this user. Try later!',effect: 'slide',speed: 600,customClass: '',customIcon: '',showIcon: true,showCloseButton: true,autoclose: true,autotimeout: 3000,gap: 20,distance: 20,type: 1,position: 'right bottom',customWrapper: ''}
    let notify_success = {status: 'success',title: 'Manage Users',text: 'User Delected Successfully!',effect: 'slide',speed: 600,customClass: '',customIcon: '',showIcon: true,showCloseButton: true,autoclose: true,autotimeout: 3000,gap: 20,distance: 20,type: 1,position: 'right bottom',customWrapper: ''}
    if (id == '') {
    return false;
    }
    if (type == 'hide') {
      $('#DeleteModal').find('.btn-outline-danger').attr('onclick', "DeleteAcc('"+id+"')");
      $('#DeleteModal').modal('show');
      return false;
    }
    $.post(cpanel_ajax_url('delete-user'), {id: id}, function(data, textStatus, xhr) {
        if (data.status == 200) {
        $('#list-' + id).fadeOut(500, function () {
            $(this).remove();
        });
        $('#DeleteModal').modal('hide');
        new Notify({ ...notify_success })
        } else {
            $('#DeleteModal').modal('hide');
            new Notify({ ...notify_error })
        }
    });
}

