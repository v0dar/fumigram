function ResendCode(id, type = 'show') {
    if (id == '') {return false;}
    if (type == 'hide') {
      $('#ResendModal').find('.btn-outline-primary').attr('onclick', "ResendCode('"+id+"')");
      $('#ResendModal').modal('show');
      return false;
    }
    $('#send').attr('disabled', true);
    $.post(cpanel_ajax_url('send-code'), {id: id}, function(data, textStatus, xhr) {
        if (data.status == 200) {  
            $('#ResendModal').modal('hide');
            $('#redirect_link').attr('href', "<?php echo cpanel('inactive-users'); ?>");
            $('#redirect_link').attr('data-ajax', "?path=inactive-users");
            $('#redirect_link').click();
            new Notify({ ...notify_success });
            let notify_success = {status: 'success',title: 'Inactive Users',text: ''+ data.message + '',effect: 'slide',speed: 600,customClass: '',customIcon: '',showIcon: true,showCloseButton: true,autoclose: true,autotimeout: 3000,gap: 20,distance: 20,type: 1,position: 'right bottom',customWrapper: ''}
        } else {
            $('#ResendModal').modal('hide');
