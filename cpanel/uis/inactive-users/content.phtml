        } else if (action_type == 'Activate') {
            $('#redirect_link').attr('href', "<?php echo cpanel('inactive-users'); ?>");
            $('#redirect_link').attr('data-ajax', "?path=inactive-users");
            $('#redirect_link').click();
            let notify_success200 = {status: 'success',title: 'Inactive Users',text: 'Users account has been activated!',effect: 'slide',speed: 600,customClass: '',customIcon: '',showIcon: true,showCloseButton: true,autoclose: true,autotimeout: 3000,gap: 20,distance: 20,type: 1,position: 'right bottom',customWrapper: ''}
            new Notify({ ...notify_success200 });
            $('#SelectedDeleteModal').modal('hide');
        } else if (action_type == 'Deactivate') {
            $('#redirect_link').attr('href', "<?php echo cpanel('inactive-users'); ?>");
            $('#redirect_link').attr('data-ajax', "?path=inactive-users");
            $('#redirect_link').click();
            $('#SelectedDeleteModal').modal('hide');
